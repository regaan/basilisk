{
    "name": "basilisk-desktop",
    "version": "1.0.8",
    "description": "Basilisk — AI Red Teaming Desktop Application",
    "homepage": "https://github.com/regaan/basilisk",
    "repository": {
        "type": "git",
        "url": "https://github.com/regaan/basilisk.git"
    },
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron .",
        "dist": "electron-builder",
        "build": "electron-builder",
        "build:linux": "electron-builder --linux",
        "build:win": "electron-builder --win",
        "build:mac": "electron-builder --mac",
        "pack": "electron-builder --dir"
    },
    "keywords": [
        "ai",
        "red-team",
        "llm",
        "security",
        "pentesting",
        "vulnerability"
    ],
    "author": "Regaan <contact@rothackers.com> (https://rothackers.com)",
    "license": "AGPL-3.0",
    "type": "commonjs",
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1"
    },
    "dependencies": {
        "electron-store": "^8.1.0",
        "electron-updater": "^6.3.9"
    },
    "build": {
        "appId": "com.rothackers.basilisk",
        "productName": "Basilisk",
        "icon": "build/icon.png",
        "linux": {
            "target": [
                "pacman",
                "AppImage",
                "deb",
                "rpm"
            ],
            "icon": "build/icon.png",
            "executableName": "basilisk",
            "artifactName": "basilisk-${version}.${ext}",
            "category": "Security",
            "maintainer": "Rot Hackers <contact@rothackers.com>"
        },
        "win": {
            "target": "nsis",
            "icon": "build/icon.ico",
            "publisherName": "Rot Hackers"
        },
        "mac": {
            "target": "dmg",
            "icon": "build/icon.icns",
            "category": "public.app-category.developer-tools"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "allowElevation": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "license": "LICENSE.txt"
        },
        "publish": {
            "provider": "github",
            "owner": "regaan",
            "repo": "basilisk"
        },
        "pacman": {
            "depends": [
                "hicolor-icon-theme"
            ]
        },
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "preload.js",
            "src/**/*"
        ],
        "extraResources": [
            {
                "from": "bin",
                "to": "bin",
                "filter": [
                    "**/*"
                ]
            }
        ]
    }
}